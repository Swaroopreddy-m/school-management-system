# Server Configuration
PORT=3000
NODE_ENV=production

# Database Connection URL (SQLite path or PostgreSQL connection string)
# SQLite default: "file:./dev.db"
# PostgreSQL default: "postgresql://username:password@localhost:5432/dbname?schema=public"
DATABASE_URL="postgresql://username:password@localhost:5432/dbname?schema=public"

# Security Configurations
# Generate a secure 64-character random string for JWT signatures
JWT_SECRET="your-secure-jwt-secret-key-change-in-production"

# SMTP Mail Server Settings (For real email alerts delivery)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="username@gmail.com"
SMTP_PASS="gmail-app-password"
SMTP_FROM="noreply@eduportal.com"
