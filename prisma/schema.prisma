datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Developer {
  id               String           @id @default(uuid())
  name             String
  email            String           @unique
  username         String           @unique
  passwordHash     String
  securityQuestion String
  securityAnswer   String
  organization     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  superAdmins      SuperAdmin[]
}

model PlatformSettings {
  id           String   @id @default(uuid())
  platformName String
  theme        String   @default("dark") // "dark" or "light"
  currency     String   @default("USD")
  timezone     String   @default("UTC")
  language     String   @default("en")
  smtpHost     String?
  smtpPort     Int?
  createdAt    DateTime @default(now())
}

model SuperAdmin {
  id           String   @id @default(uuid())
  developerId  String
  developer    Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
  name         String
  email        String   @unique
  username     String   @unique
  passwordHash String
  phone        String?
  country      String?
  timezone     String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  schools      School[]
}

model School {
  id               String       @id @default(uuid())
  schoolName       String
  schoolCode       String       @unique
  email            String
  phone            String
  address          String
  city             String
  country          String
  timezone         String
  logo             String?      // path or base64
  status           String       @default("ACTIVE") // ACTIVE, INACTIVE
  subscriptionTier String       @default("BASIC")
  features         String       @default("attendance,fees,exams,library")
  createdBy        String
  creator          SuperAdmin   @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  users            SchoolUser[]
}

model SchoolUser {
  id           String   @id @default(uuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name         String
  email        String
  username     String
  passwordHash String
  role         String   // SCHOOL_ADMIN, PRINCIPAL, VICE_PRINCIPAL, TEACHER, STUDENT, PARENT, ACCOUNTANT, LIBRARIAN, RECEPTIONIST
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@unique([schoolId, username])
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String
  actorName String
  actorType String   // DEVELOPER, SUPER_ADMIN, SCHOOL_USER
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())
}
